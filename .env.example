# PostgreSQLの接続URL（Neonの無料枠などを推奨。ローカル開発も同じ形式）
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Vercel Blob（Vercelダッシュボードで Blob ストアを作ると発行される。
# 未設定ならローカルの public/uploads に保存する）
BLOB_READ_WRITE_TOKEN=""

# LINE Messaging API（LINE Developers コンソールで発行）
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""

# 週次送信cronの認証用シークレット（任意の長いランダム文字列）
CRON_SECRET=""

# 執筆スタジオのセッションCookie署名用シークレット（任意の長いランダム文字列）。
# 未設定なら CRON_SECRET を流用する。
SESSION_SECRET=""

# Claude（Anthropic）APIキー。リアクション・深掘り・章の自動執筆に使う。
# 未設定でもWeb/LINEは動く（リアクション等は温かい定型文にフォールバック）。
ANTHROPIC_API_KEY=""

# 音声の文字起こし（Whisper）。未設定なら音声は保存のみ（文字起こしは後ほど）。
OPENAI_API_KEY=""

# マジックリンク・回答ページURLの生成に使う公開URL
APP_BASE_URL="http://localhost:3000"

# Stripe（決済）。未設定なら開発用モック決済にフォールバックする
# （/register/checkout/mock で擬似決済し、実際の請求は発生しない）。
# 設定すると本番Checkoutへ。実連携は src/lib/billing.ts の createCheckout に入れる。
STRIPE_SECRET_KEY=""

# メール送信（語り手への招待・贈り主への通知）。未設定ならコンソール出力のみ。
# Resend か SMTP のどちらかを設定すると有効化（実連携は src/lib/email.ts）。
RESEND_API_KEY=""
SMTP_URL=""
