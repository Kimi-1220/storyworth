# PostgreSQLの接続URL（Neonの無料枠などを推奨。ローカル開発も同じ形式）
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Vercel Blob（Vercelダッシュボードで Blob ストアを作ると発行される。
# 未設定ならローカルの public/uploads に保存する）
BLOB_READ_WRITE_TOKEN=""

# LINE Messaging API（LINE Developers コンソールで発行）
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""

# 週次送信cronの認証用シークレット（任意の長いランダム文字列）
CRON_SECRET=""

# 回答ページURLの生成に使う公開URL
APP_BASE_URL="http://localhost:3000"
