generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// アカウント（口座の持ち主＝購入者）。登録導線[3]で決済より前に作られる。
// アンカーは email。Path A（self）はアカウント＝語り手、Path B（gift）は
// 贈り主が語り手を1人以上所有する。→ docs/registration-flow.md「データモデルへの示唆」
model Account {
  id              String        @id @default(cuid())
  email           String        @unique // 登録のアンカー。Stripe任せにせず自前で先に取る
  fullName        String
  kind            String // "self"（自分の自伝）| "gift"（家族への贈り物）
  plan            String // "basic" | "standard" | "premium"
  copies          Int           @default(1) // 発行部数（価格の数量ライン）
  status          String        @default("unpaid") // "unpaid"（カゴ落ち）| "paid"
  notifyChannel   String? // "line" | "email"（ギフト時：贈り主への進捗・完成連絡）
  notifyEmail     String? // 贈り主の連絡先メール（通常はemailと同じ。別宛先も可）
  stripeSessionId String? // 決済セッションID（モック時は "mock_..."）
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  storytellers    Storyteller[]
}

// 語り手（親・祖母など、質問に答える人。self の場合は購入者本人）
model Storyteller {
  id            String      @id @default(cuid())
  name          String
  lineUserId    String?     @unique
  linkCode      String      @unique // LINE連携用の6桁コード
  account       Account?    @relation(fields: [accountId], references: [id])
  accountId     String?
  relationship  String      @default("self") // "self" | "母" | "父" | "祖母" | "祖父" | "その他"
  status        String      @default("active") // "active" | "pending-invite"（ギフトで未着地）
  inviteMethod  String? // "line" | "email" | "print"（[4]の“予告”で選ぶ送信手段）
  inviteMessage String? // 語り手へ届ける送信文言（prefill編集後）
  notifyChannel String? // "line" | "email"（質問配信チャネル）
  notifyEmail   String? // 質問配信先メール
  phone         String? // プレミアム電話取材の連絡先
  callDay       String? // 取材の曜日
  callTime      String? // 取材の時間帯
  createdAt     DateTime    @default(now())
  prompts       Prompt[]
  magicLinks    MagicLink[]
  chapters      Chapter[]
  sections      Section[]

  @@index([accountId])
}

// 執筆スタジオへのマジックリンク（1回限り・短命トークン）。
// LINE等の通知に貼り、タップだけでログイン済みのスタジオが開く。
// → docs/writing-studio.md「着地の設計」
model MagicLink {
  token         String      @id // URLセーフなランダムトークン
  storyteller   Storyteller @relation(fields: [storytellerId], references: [id])
  storytellerId String
  promptId      String? // 開いた直後に見せたい出題（任意）
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime    @default(now())

  @@index([storytellerId])
}

// 章。カテゴリ（章テーマ）ごとに1つ。本文はセクションの集まりで構成し、
// 章自体はタイトルだけが内容に合わせて更新されていく。
// → docs/novel.md / docs/writing-studio.md
model Chapter {
  id            String      @id @default(cuid())
  storyteller   Storyteller @relation(fields: [storytellerId], references: [id])
  storytellerId String
  category      String // 質問カテゴリ＝章のテーマ
  title         String
  body          String? // 旧: 章まるごとの下書き（現在は未使用・セクションに移行）
  sortOrder     Int         @default(0)
  updatedAt     DateTime    @updatedAt
  createdAt     DateTime    @default(now())

  @@unique([storytellerId, category])
}

// セクション。1質問（出題）= 1セクション。
// 回答するとそのセクションだけを生成。本人が編集でき、後から回答が
// 加わっても既存の言い回し・事実は極力保ったまま追記の文脈だけ織り込む。
model Section {
  id            String      @id @default(cuid())
  storyteller   Storyteller @relation(fields: [storytellerId], references: [id])
  storytellerId String
  prompt        Prompt      @relation(fields: [promptId], references: [id])
  promptId      String      @unique
  category      String // 所属する章テーマ
  body          String // 生成 or 本人編集後の本文
  edited        Boolean     @default(false) // 本人が手で編集したか
  sortOrder     Int         @default(0)
  updatedAt     DateTime    @updatedAt
  createdAt     DateTime    @default(now())

  @@index([storytellerId, category])
}

// 質問マスタ（data/questions.json から seed で投入）
model Question {
  id        String   @id @default(cuid())
  category  String
  source    String // "storyworth" | "vault"
  text      String   @unique
  sortOrder Int
  prompts   Prompt[]
}

// 語り手への出題（質問のインスタンス）
model Prompt {
  id            String      @id @default(cuid())
  storyteller   Storyteller @relation(fields: [storytellerId], references: [id])
  storytellerId String
  question      Question    @relation(fields: [questionId], references: [id])
  questionId    String
  status        String      @default("open") // "open" | "answered" | "skipped"
  novelText     String? // 小説的に書き換えた問いかけ（スタジオ表示用）
  reaction      String? // 直近回答へのLLMリアクション
  followups     String? // やさしい深掘り質問（改行区切り）
  sentAt        DateTime?
  createdAt     DateTime    @default(now())
  answers       Answer[]
  section       Section?
  interviewMessages InterviewMessage[]

  @@unique([storytellerId, questionId])
}

// 取材（チャット）のAI側の発言ログ。リアクション・深掘りを1ターンずつ残し、
// 完全な会話履歴として表示できるようにする。
// 語り手の発言は Answer 側に残るので、表示時は createdAt で両者を時系列マージする。
model InterviewMessage {
  id        String   @id @default(cuid())
  prompt    Prompt   @relation(fields: [promptId], references: [id])
  promptId  String
  role      String // "reaction" | "followups"
  text      String
  createdAt DateTime @default(now())

  @@index([promptId])
}

// 回答。1つの出題に複数回答可（テキスト + 写真 + 音声の組み合わせ）
model Answer {
  id        String   @id @default(cuid())
  prompt    Prompt   @relation(fields: [promptId], references: [id])
  promptId  String
  type      String // "text" | "image" | "audio"
  text      String?
  mediaPath String? // public/ 配下の相対パス（本番ではS3等のキーに置き換え）
  via       String // "line" | "web"
  createdAt DateTime @default(now())
}
